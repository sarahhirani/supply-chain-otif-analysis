      <aliases enabled='yes' />
      <column caption='OTIF %' datatype='real' name='[Calculation_2468746695951802368]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([OTIF_Flag])/COUNT([Order ID])' />
      </column>
      <column caption='Fill Rate' datatype='real' name='[Calculation_2468746695952109569]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Shipped_Qty])/SUM([Ordered_Qty])' />
      </column>
      <column caption='Backorder Rate' datatype='real' name='[Calculation_2468746695952379906]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Ordered_Qty] - [Shipped_Qty]) / SUM([Ordered_Qty])' />
      </column>
      <column caption='Avg Delay' datatype='real' name='[Calculation_2468746695952945155]' role='measure' type='quantitative'>
